# Base
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/multi_upload
BACKEND_URL=http://localhost:8080

# Redis (BullMQ)
REDIS_URL=redis://default:password@localhost:6379

# AWS S3 or Cloudflare R2 (S3 compatible)
S3_REGION=us-east-1
S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=yyy

# Google OAuth (YouTube)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Firebase / Firestore (backend Go)
FIREBASE_PROJECT_ID=easy-publishing
GOOGLE_APPLICATION_CREDENTIALS=backend/firebase-service-account.json

# NextAuth (optional, not required in MVP)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret
